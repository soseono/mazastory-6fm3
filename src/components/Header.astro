---
import { Search } from 'lucide-astro';
import { getSiteConfig } from '../lib/api';

const siteConfig = await getSiteConfig();
const blogName = siteConfig?.blog_name || "Maza Blog";
const currentLang = Astro.locals.lang || 'ko';
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white/80 backdrop-blur-md transition-all">
  <div class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6">
    <a href="/" class="flex items-center gap-2">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-[var(--color-indigo-600)] text-white font-bold shadow-lg shadow-[var(--color-indigo-200)]">
        {blogName.charAt(0).toUpperCase()}
      </div>
      <span class="text-xl font-black italic tracking-tight text-[var(--color-indigo-700)]">
        {blogName}
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8 text-sm font-semibold text-slate-600">
      <a href="/" class="hover:text-[var(--color-indigo-600)] transition-colors">Home</a>
      <a href="/about" class="hover:text-[var(--color-indigo-600)] transition-colors">About</a>
    </nav>

    <div class="flex items-center gap-4">
      <!-- Language Switcher -->
      <div class="hidden sm:flex items-center gap-2 text-xs font-semibold text-slate-500">
        <a href="/" class={`transition-colors ${currentLang === 'ko' ? 'text-[var(--color-indigo-600)] font-black' : 'hover:text-[var(--color-indigo-600)]'}`}>KR</a>
        <span class="text-slate-300">|</span>
        <a href="/en" class={`transition-colors ${currentLang === 'en' ? 'text-[var(--color-indigo-600)] font-black' : 'hover:text-[var(--color-indigo-600)]'}`}>EN</a>
        <span class="text-slate-300">|</span>
        <a href="/ja" class={`transition-colors ${currentLang === 'ja' ? 'text-[var(--color-indigo-600)] font-black' : 'hover:text-[var(--color-indigo-600)]'}`}>JA</a>
      </div>

      <button class="p-2 text-slate-400 hover:text-[var(--color-indigo-600)] transition-colors rounded-full hover:bg-[var(--color-indigo-50)]">
        <Search size={20} />
      </button>
    </div>
  </div>
</header>
