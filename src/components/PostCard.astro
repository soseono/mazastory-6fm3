---
import type { Post } from '../lib/api';

interface Props {
  post: Post;
}

const { post } = Astro.props;
// Default language for formatted dates; can be extended to accept a prop later.
const lang = 'ko';
const dateLocales: Record<string, string> = { ko: 'ko-KR', en: 'en-US', ja: 'ja-JP' };
const formattedDate = new Date(post.publish_at || post.created_at).toLocaleDateString(dateLocales[lang] || 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
const tArticle = lang === 'ko' ? '아티클' : lang === 'ja' ? '記事' : 'Article';

// 실제 이미지 추출: metadata.data.image1 → metadata.blocks 이미지 → 폴백
const metaImage = post.metadata?.data?.image1 
  || post.metadata?.blocks?.find((b: any) => b.type === 'image')?.url
  || null;

// 고정된 폴백 이미지 대신 CSS 그라디언트를 사용 (가짜 이미지 요청을 방지하여 속도 대폭 개선)
const coverImage = metaImage || null;

// 안전한 텍스트 추출 (content가 null일 경우 html_content에서 태그 제거)
const plainText = post.content || (post.html_content ? post.html_content.replace(/<[^>]*>?/gm, '') : '');
const excerpt = plainText.length > 150 ? plainText.substring(0, 150) + '...' : plainText;
---

<a href={`/${post.slug || post.id}`} class="group flex flex-col overflow-hidden rounded-2xl bg-white border border-slate-100 shadow-sm transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-indigo-50 hover:border-indigo-100">
  <div class="relative aspect-[16/9] w-full overflow-hidden bg-slate-100">
    {coverImage ? (
      <img 
        src={coverImage} 
        alt={post.title}
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="h-full w-full bg-gradient-to-br from-indigo-100 to-purple-50 flex items-center justify-center">
        <span class="text-indigo-300 font-bold text-4xl opacity-50">{post.title.substring(0, 1)}</span>
      </div>
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 transition-opacity group-hover:opacity-100"></div>
  </div>
  
  <div class="flex flex-1 flex-col p-5 md:p-6">
    <div class="mb-3 flex items-center gap-2">
      <span class="rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs font-bold text-indigo-600">
        {tArticle}
      </span>
      <span class="text-xs font-medium text-slate-400">
        {formattedDate}
      </span>
    </div>
    
    <h3 class="mb-2 text-lg sm:text-xl font-bold leading-tight text-slate-900 group-hover:text-indigo-600 transition-colors line-clamp-2">
      {post.title}
    </h3>
    
    <p class="text-sm text-slate-500 line-clamp-3">
      {excerpt}
    </p>
  </div>
</a>
