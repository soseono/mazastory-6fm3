---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { getApprovedPosts, getRequestDomain } from '../../lib/api';

const domain = getRequestDomain(Astro.request);
const pageParam = Astro.params.page;
const page = parseInt(pageParam || '1', 10);

if (isNaN(page) || page < 1) {
  return Astro.redirect('/404');
}

const allPosts = await getApprovedPosts(domain, Astro.locals.lang || 'ko');
// index.astro에서 featuredPost 1개 + 첫 9개를 보여줬음 (총 10개)
// 따라서 /page/2 에서는 11번째 포스트부터 보여주면 됨
const postsPerPage = 9;
const offset = 1 + (page - 1) * postsPerPage;

const pagePosts = allPosts.slice(offset, offset + postsPerPage);
const hasNextPage = allPosts.length > offset + postsPerPage;

if (pagePosts.length === 0 && page > 1) {
  return Astro.redirect('/404');
}
---

<Layout title={`전체 글 - ${page}페이지`} description={`전체 포스트 목록 ${page}페이지입니다.`}>
  <div class="mx-auto max-w-5xl px-6 pt-12 pb-20 md:pt-20">
    
    <header class="mb-14 text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-slate-100 px-4 py-1.5 text-sm font-bold text-slate-500 border border-slate-200">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        <a href="/" class="hover:text-indigo-600 transition-colors">홈으로 돌아가기</a>
      </div>
      <h1 class="text-4xl font-black tracking-tight text-slate-900 md:text-5xl">
        전체 글 <span class="text-indigo-600 font-medium text-2xl ml-2">Page {page}</span>
      </h1>
    </header>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {pagePosts.map(post => (
        <PostCard post={post} />
      ))}
    </div>

    <div class="mt-16 flex items-center justify-between border-t border-slate-200 pt-8">
      {page > 2 ? (
        <a href={`/page/${page - 1}`} class="inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-100 hover:text-slate-900 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          이전 페이지
        </a>
      ) : (
        <a href="/" class="inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-100 hover:text-slate-900 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          첫 페이지
        </a>
      )}

      {hasNextPage ? (
        <a href={`/page/${page + 1}`} class="inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-100 hover:text-slate-900 transition-colors">
          다음 페이지
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      ) : (
        <div class="px-4 py-2 text-sm font-medium text-slate-400">마지막 페이지</div>
      )}
    </div>
  </div>
</Layout>
