---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';
import AnalyticsTracker from '../components/AnalyticsTracker.astro';
import { getSiteConfig, getRequestDomain, getApprovedPosts, getPostBySlug } from '../lib/api';
import { buildKeywordMap, injectInternalLinks } from '../lib/internalLinks';
import { splitHtmlForAd } from '../lib/adManager';

// CDN 캐싱 활성화: 쿠키 의존성 제거로 Cloudflare/Netlify 캐싱이 작동함
// - 개인 정보(쿠키 등) 없음 → CDN이 페이지를 저장해 전 세계 방문자에게 즉시 제공
Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=3600, stale-while-revalidate=86400');

const domain = getRequestDomain(Astro.request);
const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

const [siteConfig, allPosts] = await Promise.all([
  getSiteConfig(domain),
  getApprovedPosts(domain, Astro.locals.lang || 'ko')
]);

import { findPostMetaInList, findPostMetaByIdHintFallback, getPostContent } from '../lib/api';

let postMeta = findPostMetaInList(allPosts, slug);
if (!postMeta) {
  postMeta = await findPostMetaByIdHintFallback(slug, siteConfig?.id || '');
}

if (!postMeta) {
  return Astro.redirect('/404');
}

const fullContent = await getPostContent(postMeta.id);
const post = { ...postMeta, content: fullContent?.content || '', html_content: fullContent?.html_content || '' };

if (!post) {
  console.log('404 for slug:', slug, 'allPosts length:', allPosts.length);
  if (allPosts.length > 0) {
    console.log('First post ID:', allPosts[0].id);
  }
  return Astro.redirect('/404');
}

// SEO 내부 링크 (이전글/다음글) 계산
const postIndex = allPosts.findIndex((p: any) => p.slug === slug || p.id === slug);
// 최신순 정렬이라서 index + 1 이 과거(이전글), index - 1 이 미래(다음글)
const prevPost = postIndex < allPosts.length - 1 ? allPosts[postIndex + 1] : null;
const nextPost = postIndex > 0 ? allPosts[postIndex - 1] : null;

// A/B 테스트: 서버 쿠키 대신 클라이언트(localStorage) 기반으로 전환
// → 서버는 항상 두 광고 슬롯을 모두 렌더링하고, 클라이언트 JS가 하나를 숨김
const keywordMap = buildKeywordMap(allPosts, post.slug);
const linkedHtmlContent = injectInternalLinks(post.html_content || post.content, keywordMap);
const [part1, part2] = splitHtmlForAd(linkedHtmlContent);

const profileName = siteConfig?.blog_name || "Maza Editor";
const dateStr = new Date(post.created_at).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });

// 실제 이미지 추출 (PostCard와 동일한 로직 적용)
const metaImage = post.metadata?.data?.image1 
  || post.metadata?.blocks?.find((b: any) => b.type === 'image')?.url
  || post.metadata?.thumbnail_url
  || post.thumbnail_url
  || null;

// Zero-IT 마법사로 자동 생성된 글인지 판별 (HTML 내부에 이미 h1 타이틀과 본문 썸네일이 포함되어 있음)
const isZeroItPost = post.html_content && post.html_content.includes('max-width:7');
---

<Layout 
	title={post.title}
	description={post.content ? post.content.substring(0, 160).replace(/<[^>]*>?/gm, '') : ""}
	image={metaImage}
	type="article"
	authorName={profileName}
	datePublished={post.created_at}
  siteConfig={siteConfig}
>
  <div class="mx-auto max-w-3xl px-4 pt-6 pb-12 md:px-6 md:pt-16 md:pb-20">
    
    <!-- 뒤로가기 -->
    <a href="/" class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-400 hover:text-[var(--color-indigo-600)] mb-6 md:mb-10 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      목록으로
    </a>

    <!-- 포스트 헤더 -->
    {!isZeroItPost && (
      <header class="mb-8 md:mb-12">
        {post.metadata?.category && (
          <a href={`/category/${encodeURIComponent(post.metadata.category)}`} class="mb-3 md:mb-4 inline-flex cursor-pointer items-center gap-1.5 rounded-full bg-[var(--color-indigo-50)] px-3 py-1 text-xs font-bold uppercase tracking-widest text-[var(--color-indigo-600)] border border-[var(--color-indigo-100)] transition-colors hover:bg-[var(--color-indigo-100)]">
            {post.metadata.category}
          </a>
        )}
        <!-- 모바일: text-2xl, 태블릿: text-4xl, PC: text-5xl -->
        <h1 class="mb-5 text-2xl font-black leading-tight tracking-tight text-slate-900 md:text-4xl lg:text-5xl break-keep">
          {post.title}
        </h1>
        
        <!-- 작성자 정보 -->
        <div class="flex items-center gap-3 text-sm text-slate-500">
          <div class="flex items-center gap-2">
            <div class="flex h-7 w-7 items-center justify-center rounded-full bg-gradient-to-br from-[var(--color-indigo-100)] to-slate-100 text-[var(--color-indigo-600)] font-bold text-xs shadow-inner">
              {profileName.charAt(0).toUpperCase()}
            </div>
            <span class="font-semibold text-slate-700">{profileName}</span>
          </div>
          <span class="h-1 w-1 rounded-full bg-slate-300"></span>
          <time datetime={post.created_at}>{dateStr}</time>
        </div>
      </header>
    )}

    <!-- 썸네일: 모바일에서 aspect-[16/9], PC에서 aspect-[21/9] -->
    {!isZeroItPost && metaImage && (
      <figure class="mb-8 md:mb-14 overflow-hidden rounded-2xl md:rounded-3xl border border-slate-100 shadow-lg md:shadow-2xl">
        <img 
          src={metaImage} 
          alt={post.title}
          class="w-full object-cover aspect-[16/9] md:aspect-[21/9]"
          loading="eager"
          fetchpriority="high"
        />
      </figure>
    )}

    <!-- 포스트 본문: 모바일은 prose(base), PC는 prose-lg -->
    <!-- prose-h1:hidden 으로 본문 안의 중복 h1 숨김 -->
    <article class="prose prose-slate max-w-none md:prose-lg
      prose-headings:font-bold prose-headings:tracking-tight prose-headings:break-keep
      prose-h1:hidden prose-h2:text-xl prose-h2:md:text-2xl prose-h3:text-lg prose-h3:md:text-xl
      prose-p:leading-relaxed prose-p:break-keep
      prose-a:text-[var(--color-indigo-600)] hover:prose-a:text-[var(--color-indigo-700)]
      prose-img:rounded-xl prose-img:md:rounded-2xl prose-img:shadow-md prose-img:mx-auto
      prose-li:break-keep">
      <Fragment set:html={part1} />

      <!-- 광고 B: 본문 중간 삽입 (클라이언트 JS가 A/B 배정 후 숨김 처리) -->
      {part2 && (
        <div id="ad-slot-mid" class="my-8 md:my-12">
          <AdSlot className="" />
        </div>
      )}
      {part2 && <Fragment set:html={part2} />}
    </article>

    <!-- 광고 A: 본문 하단 (클라이언트 JS가 A/B 배정 후 숨김 처리) -->
    <div id="ad-slot-bottom" class="mt-10 md:mt-16">
      <AdSlot className="" />
    </div>

    <!-- 공유 및 해시태그 -->
    <div class="mt-10 md:mt-16 bg-slate-50 rounded-3xl p-6 border border-slate-100 flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex flex-wrap gap-2 justify-center md:justify-start">
        {post.metadata?.hashtags && post.metadata.hashtags.map((tag: string) => (
          <a href={`/tag/${encodeURIComponent(tag.replace(/^#/, ''))}`} class="rounded-full bg-white px-3 py-1.5 text-xs md:text-sm font-semibold text-slate-600 border border-slate-200 hover:bg-slate-100 hover:text-indigo-600 hover:border-indigo-200 transition-colors cursor-pointer shadow-sm">
            #{tag.replace(/^#/, '')}
          </a>
        ))}
      </div>

      <button 
        id="share-btn" 
        class="group w-full md:w-auto flex-shrink-0 inline-flex items-center justify-center gap-2 rounded-2xl bg-indigo-600 px-6 py-3.5 text-sm font-black text-white shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 hover:shadow-indigo-600/40 hover:-translate-y-0.5 transition-all"
        title="링크 복사하기"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" x2="12" y1="2" y2="15"/></svg>
        <span id="share-text">이 글 공유하기 (링크 복사)</span>
      </button>
    </div>

    <!-- 하단 네비게이션 (이전글 / 홈 / 다음글) -->
    <div class="mt-12 md:mt-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <!-- 이전글 -->
        <div class="flex justify-start order-2 md:order-1">
        {prevPost ? (
          <a href={`/${prevPost.slug || prevPost.id}`} class="group flex flex-col justify-center rounded-2xl border border-slate-200 bg-white p-5 hover:border-indigo-300 hover:shadow-md transition-all text-left w-full h-full">
            <span class="mb-2 text-[10px] font-black uppercase tracking-widest text-slate-400 group-hover:text-indigo-500">← Previous Post</span>
            <span class="text-sm font-bold text-slate-800 line-clamp-2">{prevPost.title}</span>
          </a>
        ) : <div class="hidden md:block w-full"></div>}
        </div>

        <!-- 홈버튼 -->
        <div class="flex justify-center items-center order-1 md:order-2 mb-4 md:mb-0">
          <a href="/" class="flex flex-col items-center justify-center w-full h-full rounded-2xl border border-slate-200 bg-slate-900 p-5 hover:bg-indigo-600 transition-colors text-slate-400 hover:text-white group">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-2 text-white group-hover:scale-110 transition-transform"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span class="text-[10px] font-black uppercase tracking-widest text-white">블로그 홈</span>
          </a>
        </div>
        
        <!-- 다음글 -->
        <div class="flex justify-end order-3 md:order-3">
        {nextPost ? (
          <a href={`/${nextPost.slug || nextPost.id}`} class="group flex flex-col justify-center rounded-2xl border border-slate-200 bg-white p-5 hover:border-indigo-300 hover:shadow-md transition-all text-right w-full h-full">
            <span class="mb-2 text-[10px] font-black uppercase tracking-widest text-slate-400 group-hover:text-indigo-500">Next Post →</span>
            <span class="text-sm font-bold text-slate-800 line-clamp-2">{nextPost.title}</span>
          </a>
        ) : <div class="hidden md:block w-full"></div>}
        </div>
      </div>
    </div>
  </div>

  <!-- 리딩 프로그레스 바 -->
  <div class="fixed top-0 left-0 h-0.5 md:h-1 bg-[var(--color-indigo-600)] z-[60] transition-all duration-100" id="reading-progress"></div>
  <AnalyticsTracker postId={post.id} adVariant="client" />
</Layout>

<script>
  // ─── A/B 광고 배정 (localStorage 기반 - CDN 캐싱 친화적) ────────────────────
  function getAdVariant(): string {
    try {
      let variant = localStorage.getItem('ad_variant');
      if (!variant) {
        variant = Math.random() < 0.5 ? 'A' : 'B';
        localStorage.setItem('ad_variant', variant);
      }
      return variant;
    } catch {
      return 'A';
    }
  }

  const variant = getAdVariant();

  // B군: 중간 광고 노출, 하단 광고 숨김
  // A군: 하단 광고 노출, 중간 광고 숨김
  if (variant === 'A') {
    const midAd = document.getElementById('ad-slot-mid');
    if (midAd) midAd.style.display = 'none';
  } else {
    const bottomAd = document.getElementById('ad-slot-bottom');
    if (bottomAd) bottomAd.style.display = 'none';
  }

  // ─── 스크롤 프로그레스 바 ────────────────────────────────────────────────────
  const progressBar = document.getElementById('reading-progress');
  if (progressBar) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
          if (height > 0) {
            progressBar.style.width = `${(scrollY / height) * 100}%`;
          }
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }

  // ─── 공유 버튼 (링크 복사) ────────────────────────────────────────────────────
  const shareBtn = document.getElementById('share-btn');
  const shareText = document.getElementById('share-text');
  if (shareBtn && shareText) {
    shareBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        const originalHtml = shareBtn.innerHTML;
        
        shareBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> <span>링크 복사 완료!</span>`;
        shareBtn.classList.remove('bg-slate-800', 'hover:bg-[var(--color-indigo-600)]');
        shareBtn.classList.add('bg-emerald-500', 'hover:bg-emerald-600');
        
        setTimeout(() => {
          shareBtn.innerHTML = originalHtml;
          shareBtn.classList.remove('bg-emerald-500', 'hover:bg-emerald-600');
          shareBtn.classList.add('bg-slate-800', 'hover:bg-[var(--color-indigo-600)]');
        }, 2500);
      } catch (err) {
        alert('링크 복사를 지원하지 않는 브라우저입니다. URL을 직접 복사해주세요.');
      }
    });
  }
</script>
