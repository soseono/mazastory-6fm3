---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { getSiteConfig, getRequestDomain } from '../lib/api';

const domain = getRequestDomain(Astro.request);
const siteConfig = await getSiteConfig(domain);
const blogName = siteConfig?.blog_name || "Maza Blog";
const contactEmail = `contact@${domain || 'example.com'}`;
---
<Layout title={`Contact ${blogName}`} description={`Contact ${blogName}`}>
  <main class="mx-auto max-w-4xl px-6 py-20 md:py-32 relative">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-fuchsia-200/30 rounded-full blur-[100px] -z-10"></div>

    <div class="overflow-hidden rounded-[40px] border border-slate-200/80 bg-white/60 backdrop-blur-2xl p-10 md:p-16 shadow-[0_32px_80px_-48px_rgba(217,70,239,0.2)] text-center">
      <div class="mb-8 inline-flex items-center gap-2 rounded-full bg-slate-100 px-4 py-2 text-sm font-bold uppercase tracking-widest text-slate-600 border border-slate-200">
        Contact Us
      </div>
      
      <h1 class="mb-6 text-4xl font-black leading-tight tracking-tight text-slate-900 md:text-5xl lg:text-6xl break-keep">
        Get in touch
      </h1>
      
      <p class="mb-12 text-lg text-slate-500 max-w-2xl mx-auto">
        문의 사항이나 제휴 제안이 있으신가요? {blogName} 팀은 언제나 여러분의 연락을 환영합니다. 아래 이메일로 편하게 연락해 주세요.
      </p>
      
      <div class="inline-block p-1 rounded-3xl bg-gradient-to-br from-indigo-500 to-fuchsia-500 shadow-xl">
        <div class="flex items-center gap-4 rounded-[22px] bg-white px-8 py-6 md:px-12 md:py-8">
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-indigo-50 text-indigo-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <div class="text-left">
            <p class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-1">Email Address</p>
            <a href={`mailto:${contactEmail}`} class="text-xl md:text-2xl font-black text-slate-900 hover:text-indigo-600 transition-colors">
              {contactEmail}
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
