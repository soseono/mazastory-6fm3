---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { getApprovedPosts, getRequestDomain, getSiteConfig } from '../lib/api';
import { useTranslation } from '../lib/i18n';

// 캐시 설정으로 로딩 속도 대폭 개선 (SWR 적용)
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=60, stale-while-revalidate=300');
Astro.response.headers.set('Netlify-CDN-Cache-Control', 'public, max-age=0, s-maxage=60, stale-while-revalidate=300');


// 서버사이드(런타임)에서 접속한 도메인 기준으로 승인된 포스트만 렌더링
// Use a simple default language; localization can be improved later.
const lang = 'ko';
const t = useTranslation(lang);
const domain = getRequestDomain(Astro.request);

// API 병렬 호출로 속도 최적화
const [siteConfig, posts] = await Promise.all([
  getSiteConfig(),
  getApprovedPosts(domain, lang)
]);

const blogName = siteConfig?.blog_name || "Maza Blog";
const blogDescription = siteConfig?.niche || "Welcome to our blog.";
const featuredPost = posts.length > 0 ? posts[0] : null;
const recentPosts = posts.slice(1);

// Featured Post 대표 이미지 추출 (가짜 이미지 로딩 방지)
let featuredImage = null;
if (featuredPost) {
  const metaImg = featuredPost.metadata?.data?.image1 
    || featuredPost.metadata?.blocks?.find((b: any) => b.type === 'image')?.url
    || featuredPost.metadata?.thumbnail_url
    || featuredPost.thumbnail_url
    || null;
  if (metaImg) featuredImage = metaImg;
}

// 사용자 설정 대문(Hero) 배경 이미지
const heroBgUrl = siteConfig?.metadata?.hero_bg_url || '/hero-bg-picasso.png';

---

<Layout preloadImage={featuredImage}>
  <div class="mx-auto max-w-5xl px-4 pt-8 pb-10 md:px-6 md:pt-20 md:pb-14">
    <section class="relative mb-10 md:mb-16 overflow-hidden rounded-3xl md:rounded-[40px] bg-slate-950 p-8 md:p-14 lg:p-20 shadow-2xl group">
      <!-- Animated Mesh Gradient Background & Grid -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute -top-[30%] -left-[10%] h-[70%] w-[50%] rounded-full bg-indigo-600/40 blur-[120px] transition-transform duration-1000 group-hover:scale-110 group-hover:translate-x-5"></div>
        <div class="absolute top-[20%] -right-[20%] h-[80%] w-[60%] rounded-full bg-fuchsia-600/30 blur-[120px] transition-transform duration-1000 group-hover:scale-110 group-hover:-translate-x-5"></div>
        <div class="absolute -bottom-[40%] left-[20%] h-[70%] w-[60%] rounded-full bg-cyan-500/20 blur-[120px] transition-transform duration-1000 group-hover:scale-110 group-hover:-translate-y-5"></div>
        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-40"></div>
        <!-- Glass overlay -->
        <div class="absolute inset-0 bg-slate-950/40 backdrop-blur-[1px]"></div>
      </div>
      
      <div class="relative z-10 grid gap-10 lg:grid-cols-[1.4fr_auto] lg:items-center">
        <div>
          <div class="mb-6 flex flex-wrap items-center gap-3">
            <span class="rounded-full border border-indigo-400/30 bg-indigo-500/20 px-5 py-2 text-xs font-black uppercase tracking-[0.2em] text-indigo-300 shadow-[0_0_15px_rgba(99,102,241,0.2)] backdrop-blur-md">
              {blogName}
            </span>
            <span class="flex h-2 w-2 rounded-full bg-indigo-400 shadow-[0_0_8px_rgba(129,140,248,0.8)] animate-pulse"></span>
          </div>
          <h1 class="max-w-3xl text-4xl font-black leading-[1.15] tracking-tighter text-transparent bg-clip-text bg-gradient-to-br from-white via-slate-100 to-slate-400 md:text-6xl lg:text-7xl break-keep drop-shadow-sm">
            {blogDescription}
          </h1>
          <p class="mt-8 max-w-2xl text-lg leading-relaxed text-slate-300/90 md:text-2xl break-keep font-medium drop-shadow-sm">
            {t.welcome}
          </p>
          <div class="mt-12 flex flex-wrap gap-4 md:gap-5">
            <a href="/about" class="group relative inline-flex items-center justify-center overflow-hidden rounded-full bg-indigo-500 px-8 py-4 text-sm font-black tracking-wide text-white shadow-[0_8px_30px_-8px_rgba(99,102,241,0.6)] transition-all duration-300 hover:scale-105 hover:bg-indigo-400 hover:shadow-[0_10px_40px_-10px_rgba(99,102,241,0.8)]">
              <span class="absolute inset-0 bg-[linear-gradient(110deg,transparent,rgba(255,255,255,0.2),transparent)] -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></span>
              <span class="relative flex items-center gap-2">
                {t.about}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </span>
            </a>
            <a href="/contact" class="group relative inline-flex items-center justify-center overflow-hidden rounded-full border-2 border-slate-700/80 bg-slate-800/40 px-8 py-4 text-sm font-bold tracking-wide text-white backdrop-blur-xl transition-all duration-300 hover:scale-105 hover:border-slate-500 hover:bg-slate-700/60 shadow-[0_8px_30px_-8px_rgba(0,0,0,0.3)]">
              <span class="relative">{t.contact}</span>
            </a>
            <a href="/privacy" class="group relative inline-flex items-center justify-center rounded-full px-5 py-4 text-sm font-medium text-slate-400 transition-colors duration-300 hover:text-white hover:bg-white/5">
              {t.privacy}
            </a>
          </div>
        </div>

        {posts.length === 0 && (
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
            <div class="group rounded-3xl border border-white/10 bg-white/5 p-6 shadow-2xl backdrop-blur-xl transition-all hover:bg-white/10">
              <p class="text-xs font-black uppercase tracking-[0.2em] text-indigo-400 drop-shadow-md">{t.pubFlow}</p>
              <p class="mt-2 text-xl font-bold text-white">{t.pubFlowDesc}</p>
            </div>
            <div class="group rounded-3xl border border-slate-700 bg-slate-900/80 p-6 text-white shadow-2xl backdrop-blur-xl transition-all hover:border-indigo-500/50">
              <p class="text-xs font-black uppercase tracking-[0.2em] text-sky-400 drop-shadow-md">{t.layout}</p>
              <p class="mt-2 text-xl font-bold">{t.layoutDesc}</p>
            </div>
            <div class="group rounded-3xl border border-white/10 bg-white/5 p-6 shadow-2xl backdrop-blur-xl transition-all hover:bg-white/10">
              <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-300 drop-shadow-md">{t.seo}</p>
              <p class="mt-2 text-xl font-bold text-white">{t.seoDesc}</p>
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- Hero / Featured Post -->
    {featuredPost && (
      <section class="mb-14 md:mb-20">
        <div class="mb-6 md:mb-8 flex items-center justify-between">
          <h2 class="text-2xl md:text-3xl font-black italic tracking-tighter text-slate-900 uppercase">{t.featured}</h2>
        </div>
        
        <a href={`/${featuredPost.slug || featuredPost.id}`} class="group relative flex flex-col md:flex-row overflow-hidden rounded-2xl md:rounded-[32px] bg-white border border-slate-100 shadow-sm transition-all hover:shadow-2xl hover:shadow-indigo-100 hover:border-indigo-100">
          <div class="relative aspect-[16/9] w-full overflow-hidden md:aspect-[2/1] lg:aspect-[2.5/1]">
            {featuredImage ? (
              <img 
                src={featuredImage} 
                alt={featuredPost.title}
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="eager"
                decoding="sync"
              />
            ) : (
              <div class="absolute inset-0 h-full w-full bg-gradient-to-br from-indigo-100 to-purple-50 flex items-center justify-center">
                <span class="text-indigo-300 font-bold text-6xl opacity-50">{featuredPost.title.substring(0, 1)}</span>
              </div>
            )}
            <!-- 1차 오버레이: 무조건 깔리는 50% 어두운 막 (가독성 절대 확보) -->
            <div class="absolute inset-0 bg-black/50"></div>
            <!-- 2차 오버레이: 텍스트가 있는 하단부를 위한 강력한 그라데이션 -->
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/80 to-transparent"></div>
          </div>
            
          <div class="absolute inset-0 flex flex-col justify-end p-6 md:p-10 lg:p-12">
            <div class="mb-3 md:mb-4 flex items-center gap-2">
              <span class="rounded-full bg-indigo-500/20 px-3 py-1 text-[10px] md:text-xs font-black uppercase tracking-wider text-indigo-300 border border-indigo-500/30 backdrop-blur-md">
                {t.latestPick}
              </span>
            </div>
            <h3 class="mb-3 md:mb-4 text-2xl md:text-3xl font-black leading-tight text-white drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)] transition-colors break-keep line-clamp-2 md:line-clamp-none">
              {featuredPost.title}
            </h3>
            <p class="mb-6 md:mb-8 text-sm md:text-base text-slate-200 font-medium drop-shadow-[0_1px_2px_rgba(0,0,0,0.8)] line-clamp-2 md:line-clamp-3">
              {((featuredPost.content || '') || (featuredPost.html_content || '').replace(/<[^>]*>?/gm, '')).substring(0, 200)}...
            </p>
            <div class="mt-auto flex items-center justify-between">
              <span class="text-sm font-bold text-white drop-shadow-md">{t.readArticle} <span class="text-indigo-400">→</span></span>
            </div>
          </div>
        </a>
      </section>
    )}

    <!-- Recent Posts Grid -->
    {recentPosts.length > 0 && (
      <section>
        <div class="mb-6 md:mb-8 flex items-center justify-between">
          <h2 class="text-xl md:text-2xl font-black italic tracking-tighter text-slate-900 uppercase">{t.recentArticles}</h2>
        </div>
        
        <div class="grid gap-6 md:gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {recentPosts.slice(0, 9).map(post => (
            <PostCard post={post} />
          ))}
        </div>
        
        {recentPosts.length > 9 && (
          <div class="mt-12 text-center">
            <a href="/page/2" class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-8 py-3 text-sm font-bold text-slate-700 shadow-sm transition-transform hover:-translate-y-0.5 hover:border-indigo-200 hover:text-indigo-700 hover:shadow-md">
              {t.loadMore}
            </a>
          </div>
        )}
      </section>
    )}

    {posts.length === 0 && (
      <div class="overflow-hidden rounded-[32px] border border-slate-200/80 bg-white/90 px-8 py-14 text-center shadow-sm md:px-12">
        <div class="mx-auto mb-6 flex h-24 w-24 items-center justify-center rounded-full bg-gradient-to-br from-slate-100 to-indigo-100 text-slate-400 shadow-inner">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </div>
        <h2 class="mb-3 text-2xl font-black tracking-tight text-slate-900">{t.emptyTitle}</h2>
        <p class="mx-auto max-w-xl text-slate-500">
          {t.emptyDesc}
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href="/about" class="rounded-full bg-indigo-600 px-5 py-3 text-sm font-bold text-white shadow-lg shadow-indigo-200 transition-transform hover:-translate-y-0.5">{t.emptyAbout}</a>
          <a href="/contact" class="rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-bold text-slate-700 transition-transform hover:-translate-y-0.5 hover:border-indigo-200 hover:text-indigo-700">{t.emptyContact}</a>
        </div>
      </div>
    )}

  </div>
</Layout>
