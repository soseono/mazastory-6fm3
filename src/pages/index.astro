---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { getApprovedPosts, getRequestDomain, getSiteConfig } from '../lib/api';

// 서버사이드(런타임)에서 접속한 도메인 기준으로 승인된 포스트만 렌더링
const domain = getRequestDomain(Astro.request);
const siteConfig = await getSiteConfig();
const blogName = siteConfig?.blog_name || "Maza Blog";
const blogDescription = siteConfig?.blog_description || "Welcome to our blog.";
const posts = await getApprovedPosts(domain, Astro.locals.lang || 'ko');
const featuredPost = posts.length > 0 ? posts[0] : null;
const recentPosts = posts.slice(1);

// Featured Post 대표 이미지 추출
let featuredImage = 'https://images.unsplash.com/photo-1550751827-4bd374c3f58b?q=80&w=1200&auto=format&fit=crop';
if (featuredPost) {
  const metaImg = featuredPost.metadata?.data?.image1 
    || featuredPost.metadata?.blocks?.find((b: any) => b.type === 'image')?.url;
  featuredImage = metaImg || 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?q=80&w=1200&auto=format&fit=crop';
}
---

<Layout>
  <div class="mx-auto max-w-5xl px-6 pt-12 pb-10 md:pt-20 md:pb-14">
    <section class="mb-14 overflow-hidden rounded-[36px] border border-slate-200/80 bg-[linear-gradient(135deg,_rgba(255,255,255,0.96),_rgba(248,250,255,0.95)_45%,_rgba(237,242,255,0.92))] p-8 shadow-[0_24px_80px_-48px_rgba(79,70,229,0.45)] md:p-12">
      <div class="grid gap-10 lg:grid-cols-[1.35fr_0.85fr] lg:items-center">
        <div>
          <div class="mb-5 flex flex-wrap items-center gap-2 text-xs font-bold uppercase tracking-[0.28em] text-slate-500">
            <span class="rounded-full bg-indigo-600 px-3 py-1 text-white tracking-[0.18em]">{blogName}</span>
          </div>
          <h1 class="max-w-2xl text-4xl font-black leading-[1.02] tracking-tight text-slate-950 md:text-6xl">
            {blogDescription}
          </h1>
          <p class="mt-5 max-w-2xl text-base leading-7 text-slate-600 md:text-lg">
            Welcome to {blogName}. Explore our latest stories, updates, and insights below.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/about" class="rounded-full bg-slate-950 px-5 py-3 text-sm font-bold text-white shadow-lg shadow-slate-900/10 transition-transform hover:-translate-y-0.5">About</a>
            <a href="/contact" class="rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-bold text-slate-700 transition-transform hover:-translate-y-0.5 hover:border-indigo-200 hover:text-indigo-700">Contact</a>
            <a href="/privacy" class="rounded-full border border-transparent px-5 py-3 text-sm font-bold text-slate-500 transition-colors hover:text-slate-900">Privacy Policy</a>
          </div>
        </div>

        {posts.length === 0 && (
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
            <div class="rounded-3xl border border-white/70 bg-white/85 p-5 shadow-sm backdrop-blur">
              <p class="text-xs font-bold uppercase tracking-[0.2em] text-indigo-600">Publishing flow</p>
              <p class="mt-2 text-lg font-bold text-slate-900">AI draft → editor review → publish approval</p>
            </div>
            <div class="rounded-3xl border border-slate-200/80 bg-slate-950 p-5 text-white shadow-sm">
              <p class="text-xs font-bold uppercase tracking-[0.2em] text-sky-300">Layout</p>
              <p class="mt-2 text-lg font-bold">Structured header, hero, cards, and legal pages.</p>
            </div>
            <div class="rounded-3xl border border-slate-200/80 bg-white/85 p-5 shadow-sm">
              <p class="text-xs font-bold uppercase tracking-[0.2em] text-slate-500">SEO ready</p>
              <p class="mt-2 text-lg font-bold text-slate-900">Clear content hierarchy and dedicated post pages.</p>
            </div>
            <div class="rounded-3xl border border-slate-200/80 bg-white/85 p-5 shadow-sm">
              <p class="text-xs font-bold uppercase tracking-[0.2em] text-slate-500">Monetization</p>
              <p class="mt-2 text-lg font-bold text-slate-900">Ad slots and partner disclosures stay visible.</p>
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- Hero / Featured Post -->
    {featuredPost && (
      <section class="mb-20">
        <div class="mb-8 flex items-center justify-between">
          <h2 class="text-3xl font-black italic tracking-tighter text-slate-900 uppercase">Featured <span class="text-indigo-600">Story</span></h2>
        </div>
        
        <a href={`/${featuredPost.slug}`} class="group relative flex flex-col md:flex-row overflow-hidden rounded-[32px] bg-white border border-slate-100 shadow-sm transition-all hover:shadow-2xl hover:shadow-indigo-100 hover:border-indigo-100">
          <div class="relative w-full md:w-3/5 overflow-hidden bg-slate-100 min-h-[300px]">
            <img 
              src={featuredImage} 
              alt={featuredPost.title}
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-black/40 to-transparent"></div>
          </div>
          
          <div class="flex w-full md:w-2/5 flex-col justify-center p-10 md:p-12">
            <div class="mb-4 flex items-center gap-2">
              <span class="rounded-full bg-indigo-100 px-3 py-1 text-xs font-black uppercase tracking-wider text-indigo-700">
                Latest Pick
              </span>
            </div>
            <h3 class="mb-4 text-3xl font-bold leading-tight text-slate-900 group-hover:text-indigo-600 transition-colors">
              {featuredPost.title}
            </h3>
            <p class="mb-8 text-base text-slate-500 line-clamp-3">
              {featuredPost.content.substring(0, 200)}...
            </p>
            <div class="mt-auto flex items-center justify-between">
              <span class="text-sm font-bold text-slate-900">Read Article <span class="text-indigo-600">→</span></span>
            </div>
          </div>
        </a>
      </section>
    )}

    <!-- Recent Posts Grid -->
    {recentPosts.length > 0 && (
      <section>
        <div class="mb-8 flex items-center justify-between">
          <h2 class="text-2xl font-black italic tracking-tighter text-slate-900 uppercase">Recent <span class="text-slate-400">Articles</span></h2>
        </div>
        
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {recentPosts.slice(0, 9).map(post => (
            <PostCard post={post} />
          ))}
        </div>
        
        {recentPosts.length > 9 && (
          <div class="mt-12 text-center">
            <a href="/page/2" class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-8 py-3 text-sm font-bold text-slate-700 shadow-sm transition-transform hover:-translate-y-0.5 hover:border-indigo-200 hover:text-indigo-700 hover:shadow-md">
              더 많은 글 보기
            </a>
          </div>
        )}
      </section>
    )}

    {posts.length === 0 && (
      <div class="overflow-hidden rounded-[32px] border border-slate-200/80 bg-white/90 px-8 py-14 text-center shadow-sm md:px-12">
        <div class="mx-auto mb-6 flex h-24 w-24 items-center justify-center rounded-full bg-gradient-to-br from-slate-100 to-indigo-100 text-slate-400 shadow-inner">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </div>
        <h2 class="mb-3 text-2xl font-black tracking-tight text-slate-900">아직 작성된 글이 없습니다.</h2>
        <p class="mx-auto max-w-xl text-slate-500">
          Maza Studio에서 포스트를 승인하면 이곳에 표시됩니다. 지금 상태는 비어 있지만, 레이아웃과 정보 구조는 이미 게시형 사이트에 맞게 준비되어 있습니다.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href="/about" class="rounded-full bg-indigo-600 px-5 py-3 text-sm font-bold text-white shadow-lg shadow-indigo-200 transition-transform hover:-translate-y-0.5">서비스 소개</a>
          <a href="/contact" class="rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-bold text-slate-700 transition-transform hover:-translate-y-0.5 hover:border-indigo-200 hover:text-indigo-700">문의하기</a>
        </div>
      </div>
    )}

  </div>
</Layout>
