---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { getApprovedPosts, getRequestDomain, getSiteConfig } from '../lib/api';
import { useTranslation } from '../lib/i18n';

// 캐시 설정으로 로딩 속도 대폭 개선
Astro.response.headers.set('Cache-Control', 'public, max-age=60, s-maxage=300');


// 서버사이드(런타임)에서 접속한 도메인 기준으로 승인된 포스트만 렌더링
// Use a simple default language; localization can be improved later.
const lang = 'ko';
const t = useTranslation(lang);
const domain = getRequestDomain(Astro.request);

// API 병렬 호출로 속도 최적화
const [siteConfig, posts] = await Promise.all([
  getSiteConfig(),
  getApprovedPosts(domain, lang)
]);

const blogName = siteConfig?.blog_name || "Maza Blog";
const blogDescription = siteConfig?.niche || "Welcome to our blog.";
const featuredPost = posts.length > 0 ? posts[0] : null;
const recentPosts = posts.slice(1);

// Featured Post 대표 이미지 추출 (가짜 이미지 로딩 방지)
let featuredImage = null;
if (featuredPost) {
  const metaImg = featuredPost.metadata?.data?.image1 
    || featuredPost.metadata?.blocks?.find((b: any) => b.type === 'image')?.url;
  if (metaImg) featuredImage = metaImg;
}

---

<Layout preloadImage={featuredImage}>
  <div class="mx-auto max-w-5xl px-4 pt-8 pb-10 md:px-6 md:pt-20 md:pb-14">
    <section class="mb-10 md:mb-14 overflow-hidden rounded-3xl md:rounded-[36px] border border-slate-200/80 bg-[linear-gradient(135deg,_rgba(255,255,255,0.96),_rgba(248,250,255,0.95)_45%,_rgba(237,242,255,0.92))] p-6 md:p-12 shadow-[0_24px_80px_-48px_rgba(79,70,229,0.45)]">
      <div class="grid gap-8 md:gap-10 lg:grid-cols-[1.35fr_0.85fr] lg:items-center">
        <div>
          <div class="mb-4 md:mb-5 flex flex-wrap items-center gap-2 text-xs font-bold uppercase tracking-[0.28em] text-slate-500">
            <span class="rounded-full bg-indigo-600 px-3 py-1 text-white tracking-[0.18em]">{blogName}</span>
          </div>
          <h1 class="max-w-2xl text-3xl font-black leading-[1.1] tracking-tight text-slate-950 md:text-5xl lg:text-6xl break-keep">
            {blogDescription}
          </h1>
          <p class="mt-4 md:mt-5 max-w-2xl text-sm leading-relaxed text-slate-600 md:text-lg break-keep">
            {t.welcome}
          </p>
          <div class="mt-6 md:mt-8 flex flex-wrap gap-2 md:gap-3">
            <a href="/about" class="rounded-full bg-slate-950 px-4 py-2.5 md:px-5 md:py-3 text-xs md:text-sm font-bold text-white shadow-lg shadow-slate-900/10 transition-transform hover:-translate-y-0.5">{t.about}</a>
            <a href="/contact" class="rounded-full border border-slate-300 bg-white px-4 py-2.5 md:px-5 md:py-3 text-xs md:text-sm font-bold text-slate-700 transition-transform hover:-translate-y-0.5 hover:border-indigo-200 hover:text-indigo-700">{t.contact}</a>
            <a href="/privacy" class="rounded-full border border-transparent px-4 py-2.5 md:px-5 md:py-3 text-xs md:text-sm font-bold text-slate-500 transition-colors hover:text-slate-900">{t.privacy}</a>
          </div>
        </div>

        {posts.length === 0 && (
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
            <div class="rounded-3xl border border-white/70 bg-white/85 p-5 shadow-sm backdrop-blur">
              <p class="text-xs font-bold uppercase tracking-[0.2em] text-indigo-600">{t.pubFlow}</p>
              <p class="mt-2 text-lg font-bold text-slate-900">{t.pubFlowDesc}</p>
            </div>
            <div class="rounded-3xl border border-slate-200/80 bg-slate-950 p-5 text-white shadow-sm">
              <p class="text-xs font-bold uppercase tracking-[0.2em] text-sky-300">{t.layout}</p>
              <p class="mt-2 text-lg font-bold">{t.layoutDesc}</p>
            </div>
            <div class="rounded-3xl border border-slate-200/80 bg-white/85 p-5 shadow-sm">
              <p class="text-xs font-bold uppercase tracking-[0.2em] text-slate-500">{t.seo}</p>
              <p class="mt-2 text-lg font-bold text-slate-900">{t.seoDesc}</p>
            </div>
            <div class="rounded-3xl border border-slate-200/80 bg-white/85 p-5 shadow-sm">
              <p class="text-xs font-bold uppercase tracking-[0.2em] text-slate-500">{t.monetization}</p>
              <p class="mt-2 text-lg font-bold text-slate-900">{t.monetizationDesc}</p>
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- Hero / Featured Post -->
    {featuredPost && (
      <section class="mb-14 md:mb-20">
        <div class="mb-6 md:mb-8 flex items-center justify-between">
          <h2 class="text-2xl md:text-3xl font-black italic tracking-tighter text-slate-900 uppercase">{t.featured}</h2>
        </div>
        
        <a href={`/${featuredPost.slug || featuredPost.id}`} class="group relative flex flex-col md:flex-row overflow-hidden rounded-2xl md:rounded-[32px] bg-white border border-slate-100 shadow-sm transition-all hover:shadow-2xl hover:shadow-indigo-100 hover:border-indigo-100">
          <div class="relative aspect-[16/9] w-full overflow-hidden md:aspect-[2/1] lg:aspect-[2.5/1]">
            {featuredImage ? (
              <img 
                src={featuredImage} 
                alt={featuredPost.title}
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="eager"
                decoding="sync"
              />
            ) : (
              <div class="absolute inset-0 h-full w-full bg-gradient-to-br from-indigo-100 to-purple-50 flex items-center justify-center">
                <span class="text-indigo-300 font-bold text-6xl opacity-50">{featuredPost.title.substring(0, 1)}</span>
              </div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/40 to-transparent"></div>
          </div>
            
          <div class="absolute inset-0 flex flex-col justify-end p-6 md:p-10 lg:p-12">
            <div class="mb-3 md:mb-4 flex items-center gap-2">
              <span class="rounded-full bg-indigo-100 px-3 py-1 text-[10px] md:text-xs font-black uppercase tracking-wider text-indigo-700">
                {t.latestPick}
              </span>
            </div>
            <h3 class="mb-3 md:mb-4 text-2xl md:text-3xl font-bold leading-tight text-white transition-colors break-keep line-clamp-2 md:line-clamp-none">
              {featuredPost.title}
            </h3>
            <p class="mb-6 md:mb-8 text-sm md:text-base text-slate-500 line-clamp-2 md:line-clamp-3">
              {((featuredPost.content || '') || (featuredPost.html_content || '').replace(/<[^>]*>?/gm, '')).substring(0, 200)}...
            </p>
            <div class="mt-auto flex items-center justify-between">
              <span class="text-sm font-bold text-slate-900">{t.readArticle} <span class="text-indigo-600">→</span></span>
            </div>
          </div>
        </a>
      </section>
    )}

    <!-- Recent Posts Grid -->
    {recentPosts.length > 0 && (
      <section>
        <div class="mb-6 md:mb-8 flex items-center justify-between">
          <h2 class="text-xl md:text-2xl font-black italic tracking-tighter text-slate-900 uppercase">{t.recentArticles}</h2>
        </div>
        
        <div class="grid gap-6 md:gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {recentPosts.slice(0, 9).map(post => (
            <PostCard post={post} />
          ))}
        </div>
        
        {recentPosts.length > 9 && (
          <div class="mt-12 text-center">
            <a href="/page/2" class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-8 py-3 text-sm font-bold text-slate-700 shadow-sm transition-transform hover:-translate-y-0.5 hover:border-indigo-200 hover:text-indigo-700 hover:shadow-md">
              {t.loadMore}
            </a>
          </div>
        )}
      </section>
    )}

    {posts.length === 0 && (
      <div class="overflow-hidden rounded-[32px] border border-slate-200/80 bg-white/90 px-8 py-14 text-center shadow-sm md:px-12">
        <div class="mx-auto mb-6 flex h-24 w-24 items-center justify-center rounded-full bg-gradient-to-br from-slate-100 to-indigo-100 text-slate-400 shadow-inner">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </div>
        <h2 class="mb-3 text-2xl font-black tracking-tight text-slate-900">{t.emptyTitle}</h2>
        <p class="mx-auto max-w-xl text-slate-500">
          {t.emptyDesc}
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href="/about" class="rounded-full bg-indigo-600 px-5 py-3 text-sm font-bold text-white shadow-lg shadow-indigo-200 transition-transform hover:-translate-y-0.5">{t.emptyAbout}</a>
          <a href="/contact" class="rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-bold text-slate-700 transition-transform hover:-translate-y-0.5 hover:border-indigo-200 hover:text-indigo-700">{t.emptyContact}</a>
        </div>
      </div>
    )}

  </div>
</Layout>
