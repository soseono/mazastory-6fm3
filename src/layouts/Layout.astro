---
import '../styles/global.css';
import Header from '../components/Header.astro';
import SEO from '../components/SEO.astro';
import Schema from '../components/Schema.astro';
import DynamicTheme from '../components/DynamicTheme.astro';
import { getSiteConfig } from '../lib/api';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article';
	authorName?: string;
	datePublished?: string;
  preloadImage?: string;
  siteConfig?: any;
}

// Prefer an explicit domain from environment when prerendering. Only call
// the Supabase RPC when a domain is available to avoid network calls during
// static prerender.
const envDomain = import.meta.env.PUBLIC_SITE_DOMAIN || import.meta.env.SITE_DOMAIN || import.meta.env.URL || '';
const siteConfig = Astro.props.siteConfig || (envDomain ? await getSiteConfig(envDomain) : null);
// Set CDN-friendly cache control for pages rendered with this layout
Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=600');
const siteTitle = siteConfig?.blog_name || "Maza Blog";
const siteDesc = siteConfig?.niche || "MazaStudio Subdomain Blog - High Quality AI Content";

const { 
	title, 
	description = siteDesc, 
	image, 
	type = 'website',
	authorName = siteTitle,
	datePublished,
	preloadImage = undefined
} = Astro.props;

const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const canonicalUrl = Astro.url.href;
---

<!doctype html>
<html lang={siteConfig?.metadata?.lang || "ko"} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<ClientRouter />
			{preloadImage && (
				<link rel="preload" as="image" href={preloadImage} />
			)}
		<SEO 
			title={pageTitle} 
			description={description} 
			image={image} 
			canonicalUrl={canonicalUrl} 
			type={type} 
		/>
		
		<Schema 
			type={type === 'article' ? 'Article' : 'WebSite'}
			title={pageTitle}
			description={description}
			url={canonicalUrl}
			image={image}
			authorName={authorName}
			datePublished={datePublished}
		/>
		<DynamicTheme siteConfig={siteConfig} />

		{siteConfig?.adsense_pub && (
			<script is:inline async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${siteConfig.adsense_pub}`} crossorigin="anonymous"></script>
		)}

		{/* 구글 서치콘솔 소유권 인증 메타 태그 — siteConfig.google_site_verification 값이 있을 때만 주입 */}
		{siteConfig?.metadata?.google_site_verification && (
			<meta name="google-site-verification" content={siteConfig.metadata.google_site_verification} />
		)}

		{/* RSS 자동 검색(autodiscovery)용 링크 */}
		<link rel="alternate" type="application/rss+xml" title={`${siteTitle} RSS Feed`} href="/rss.xml" />
	</head>
	<body class="relative overflow-x-hidden bg-slate-50 text-slate-900 antialiased selection:bg-indigo-100 selection:text-indigo-900">
		<div aria-hidden="true" class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,_rgba(79,70,229,0.12),_transparent_30%),radial-gradient(circle_at_top_right,_rgba(14,165,233,0.1),_transparent_28%),linear-gradient(to_bottom,_rgba(255,255,255,0.92),_rgba(248,250,252,1))]"></div>
		<Header siteConfig={siteConfig} />
		
		<main class="relative z-10 min-h-screen">
			<slot />
		</main>

		<footer class="relative z-10 mt-20 border-t border-slate-200/80 bg-white/80 py-12 text-center backdrop-blur-sm">
			<div class="mx-auto max-w-5xl px-6">
				<div class="mb-6 flex justify-center items-center gap-2">
					<div class="flex h-6 w-6 items-center justify-center rounded bg-slate-900 text-[10px] text-white font-bold">
						{siteTitle.charAt(0).toUpperCase()}
					</div>
					<span class="text-sm font-black italic tracking-tight text-slate-900">{siteTitle.toUpperCase()}</span>
				</div>
				<nav class="mb-6 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs font-semibold text-slate-500">
					<a href="/about" class="hover:text-indigo-600 transition-colors">About</a>
					<a href="/contact" class="hover:text-indigo-600 transition-colors">Contact</a>
					<a href="/privacy" class="hover:text-indigo-600 transition-colors">Privacy Policy</a>
					<a href="/disclaimer" class="hover:text-indigo-600 transition-colors">Disclaimer</a>
					<a href="/rss.xml" class="hover:text-indigo-600 transition-colors">RSS</a>
				</nav>
				<p class="text-xs text-slate-500 font-medium">
					© {new Date().getFullYear()} {siteTitle}. All rights reserved. 
					<br class="md:hidden" />
					Powered by Astro & Supabase.
				</p>
			</div>
		</footer>
	</body>
</html>

